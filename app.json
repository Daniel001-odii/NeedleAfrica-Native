{
  "expo": {
    "name": "NeedleX",
    "slug": "needleafrica-app",
    "scheme": "needlex",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF5678"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.needleafrica.app",
      "appleTeamId": "9N26JG3MGB",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "googleServicesFile": "google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.needleafrica.app"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-image.png",
          "imageWidth": 100,
          "resizeMode": "contain",
          "backgroundColor": "#FF5678",
          "dark": {
            "image": "./assets/splash-image.png",
            "backgroundColor": "#FF5678"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            }
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin/app.plugin.js",
        {
          "iosUrlScheme": "com.googleusercontent.apps.818250734262-na9hqkuq758b6id6gab1ohonot5qram9"
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-notifications",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "98abe4c7-3401-411c-bdf7-8ce4adb0f761"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/98abe4c7-3401-411c-bdf7-8ce4adb0f761",
      "enabled": true
    },
    "owner": "daniel_odii"
  }
}